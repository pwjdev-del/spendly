{
  "expo": {
    "name": "Spendly",
    "slug": "spendly",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "spendly",
    "splash": {
      "backgroundColor": "#09090b"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.spendly.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#09090b"
      },
      "package": "com.spendly.app"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ]
  }
}