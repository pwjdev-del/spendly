generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id                     String             @id @default(cuid())
  name                   String
  slug                   String             @unique
  inviteCode             String?            @unique
  logoUrl                String?
  primaryColor           String?            @default("#09090b")
  currency               String             @default("USD")
  requireApproval        Boolean            @default(true)
  updatedAt              DateTime           @updatedAt
  createdAt              DateTime           @default(now())
  subscriptionMonitoring Boolean            @default(true)
  auditLogs              AuditLog[]
  cards                  Card[]
  discussions            Discussion[]
  expenses               Expense[]
  invites                Invite[]
  recurringExpenses      RecurringExpense[]
  savedSearches          SavedSearch[]
  smartLimits            SmartLimit[]
  subscriptions          Subscription[]
  todoItems              TodoItem[]
  transactions           Transaction[]
  trips                  Trip[]
  users                  User[]
}

model User {
  id                    String                @id @default(cuid())
  name                  String?
  image                 String?
  email                 String                @unique
  emailVerified         DateTime?
  password              String?
  role                  String                @default("MEMBER")
  organizationId        String?
  canReconcile          Boolean               @default(false)
  dashboardLayout       String?
  status                String                @default("ACTIVE")
  payoutDay             Int?                  @default(15)
  monthlyLimit          Int?                  @default(500000)
  bio                   String?
  avatarUrl             String?
  phoneNumber           String?
  preferences           String?               @default("{}")
  resetToken            String?               @unique
  resetTokenExpiry      DateTime?
  encryptedDataKey      String?
  updatedAt             DateTime              @updatedAt
  createdAt             DateTime              @default(now())
  rewardsBalance        Int                   @default(0)
  gamificationEnabled   Boolean               @default(true)
  accounts              Account[]
  auditLogs             AuditLog[]
  cards                 Card[]
  expenses              Expense[]
  incomes               Income[]
  authoredMessages      Message[]             @relation("MessageAuthor")
  mentionedIn           MessageMention[]      @relation("MentionedInMessage")
  notifications         Notification[]
  reconciliationBatches ReconciliationBatch[]
  recurringExpenses     RecurringExpense[]
  savedSearches         SavedSearch[]         @relation("SavedSearchOwner")
  subscriptions         Subscription[]
  tags                  Tag[]
  tasks                 Task[]
  taskLists             TaskList[]
  todoItems             TodoItem[]
  transactions          Transaction[]
  approvedTrips         Trip[]                @relation("TripApprover")
  auditedTrips          Trip[]                @relation("TripAuditor")
  trips                 Trip[]
  organization          Organization?         @relation(fields: [organizationId], references: [id])
  employeeProfile       EmployeeProfile?
  leaveRecords          LeaveRecord[]
  payslips              Payslip[]
  performanceReviews    PerformanceReview[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Income {
  id        String   @id @default(cuid())
  amount    Int
  source    String   @default("Manual")
  date      DateTime @default(now())
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])
}

model Expense {
  id                    String               @id @default(cuid())
  amount                Int
  currency              String               @default("USD")
  merchant              String
  category              String
  date                  DateTime             @default(now())
  status                String               @default("PENDING")
  receiptUrl            String?
  userId                String
  organizationId        String
  tripId                String?
  reconciliationStatus  String               @default("UNRECONCILED")
  reconciliationBatchId String?
  latitude              Float?
  longitude             Float?
  locationName          String?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  isPerDiem             Boolean              @default(false)
  autoApproved          Boolean              @default(false)
  approvedBy            String?
  approvedAt            DateTime?
  rejectedBy            String?
  rejectedAt            DateTime?
  exchangeRate          Float?
  originalAmount        Int?
  originalCurrency      String?
  organization          Organization         @relation(fields: [organizationId], references: [id])
  reconciliationBatch   ReconciliationBatch? @relation(fields: [reconciliationBatchId], references: [id])
  trip                  Trip?                @relation(fields: [tripId], references: [id])
  user                  User                 @relation(fields: [userId], references: [id])
  transaction           Transaction?

  @@index([status])
  @@index([category])
  @@index([merchant])
  @@index([createdAt])
  @@index([organizationId])
  @@index([userId])
  @@index([userId, status])
  @@index([userId, createdAt])
  @@index([organizationId, status])
  @@index([organizationId, createdAt])
  @@index([userId, category, createdAt])
}

model Card {
  id             String       @id @default(cuid())
  nickname       String?
  last4          String
  limit          Int
  spent          Int          @default(0)
  userId         String
  organizationId String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id])
  user           User         @relation(fields: [userId], references: [id])
}

model Trip {
  id             String         @id @default(cuid())
  tripNumber     String
  name           String
  description    String?
  startDate      DateTime
  endDate        DateTime?
  budget         Int?
  status         String         @default("PLANNING")
  userId         String
  organizationId String?
  approverId     String?
  auditorId      String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  expenses       Expense[]
  tasks          Task[]
  approver       User?          @relation("TripApprover", fields: [approverId], references: [id])
  auditor        User?          @relation("TripAuditor", fields: [auditorId], references: [id])
  organization   Organization?  @relation(fields: [organizationId], references: [id])
  user           User           @relation(fields: [userId], references: [id])
  documents      TripDocument[]

  @@index([organizationId])
  @@index([userId])
}

model Transaction {
  id             String       @id @default(cuid())
  date           DateTime
  amount         Int
  description    String
  source         String
  status         String       @default("PENDING")
  expenseId      String?      @unique
  userId         String
  organizationId String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  expense        Expense?     @relation(fields: [expenseId], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id])
  user           User         @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([organizationId])
}

model Invite {
  id             String       @id @default(cuid())
  code           String       @unique
  role           String
  expiresAt      DateTime
  organizationId String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@index([code])
}

model ReconciliationBatch {
  id        String    @id @default(cuid())
  name      String
  fileName  String
  date      DateTime  @default(now())
  userId    String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  expenses  Expense[]
  user      User      @relation(fields: [userId], references: [id])
}

model TripDocument {
  id         String   @id @default(cuid())
  name       String
  url        String
  type       String
  size       Int
  tripId     String
  uploadedBy String
  createdAt  DateTime @default(now())
  trip       Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
}

model RecurringExpense {
  id             String        @id @default(cuid())
  merchant       String
  amount         Int
  currency       String        @default("USD")
  category       String
  frequency      String        @default("MONTHLY")
  status         String        @default("ACTIVE")
  nextDueDate    DateTime
  userId         String
  organizationId String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  organization   Organization? @relation(fields: [organizationId], references: [id])
  user           User          @relation(fields: [userId], references: [id])

  @@index([organizationId])
  @@index([userId])
}

model AuditLog {
  id             String        @id @default(cuid())
  action         String
  entityType     String
  entityId       String?
  actorId        String
  organizationId String?
  metadata       String?
  encryptedData  String?
  createdAt      DateTime      @default(now())
  actor          User          @relation(fields: [actorId], references: [id])
  organization   Organization? @relation(fields: [organizationId], references: [id])

  @@index([actorId])
  @@index([organizationId])
  @@index([action])
}

model SecurityEvent {
  id        String   @id @default(cuid())
  ipAddress String
  type      String
  details   String?
  createdAt DateTime @default(now())

  @@index([ipAddress])
  @@index([createdAt])
}

model BlockedIp {
  ipAddress String   @id
  reason    String
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model IdempotencyKey {
  key       String   @id
  userId    String
  createdAt DateTime @default(now())
  expiresAt DateTime

  @@index([userId])
}

model SavedSearch {
  id             String        @id @default(cuid())
  name           String
  typeScope      String        @default("ALL")
  queryString    String
  uiStateJson    String?
  isPinned       Boolean       @default(false)
  isShared       Boolean       @default(false)
  ownerId        String
  organizationId String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  organization   Organization? @relation(fields: [organizationId], references: [id])
  owner          User          @relation("SavedSearchOwner", fields: [ownerId], references: [id])

  @@index([ownerId])
  @@index([organizationId])
}

model Discussion {
  id             String       @id @default(cuid())
  entityType     String
  entityId       String
  organizationId String
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id])
  messages       Message[]

  @@unique([entityType, entityId])
  @@index([organizationId])
}

model Message {
  id           String              @id @default(cuid())
  body         String
  bodyHtml     String?
  discussionId String
  authorId     String
  parentId     String?
  createdAt    DateTime            @default(now())
  editedAt     DateTime?
  deletedAt    DateTime?
  author       User                @relation("MessageAuthor", fields: [authorId], references: [id])
  discussion   Discussion          @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  parent       Message?            @relation("MessageReplies", fields: [parentId], references: [id])
  replies      Message[]           @relation("MessageReplies")
  attachments  MessageAttachment[]
  mentions     MessageMention[]

  @@index([discussionId])
  @@index([authorId])
  @@index([parentId])
}

model MessageMention {
  id              String  @id @default(cuid())
  messageId       String
  mentionedUserId String
  mentionedUser   User    @relation("MentionedInMessage", fields: [mentionedUserId], references: [id])
  message         Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([messageId, mentionedUserId])
}

model MessageAttachment {
  id        String   @id @default(cuid())
  messageId String
  fileName  String
  fileUrl   String
  fileType  String
  fileSize  Int
  createdAt DateTime @default(now())
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
}

model Notification {
  id         String    @id @default(cuid())
  type       String
  userId     String
  entityType String
  entityId   String
  messageId  String?
  title      String
  body       String?
  readAt     DateTime?
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([userId, readAt])
}

model TodoItem {
  id             String        @id @default(cuid())
  userId         String
  organizationId String?
  entityType     String
  entityId       String
  kind           String
  priority       Int           @default(0)
  reason         String
  primaryAction  String
  createdAt      DateTime      @default(now())
  resolvedAt     DateTime?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  user           User          @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([organizationId])
  @@index([resolvedAt])
}

model MerchantMapping {
  id         String   @id @default(cuid())
  bankName   String
  mappedName String
  userId     String
  usageCount Int      @default(1)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([bankName, userId])
  @@index([userId])
  @@index([bankName])
}

model TaskList {
  id        String   @id @default(cuid())
  name      String
  color     String?
  icon      String?
  isSystem  Boolean  @default(false)
  ownerId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tasks     Task[]
  owner     User     @relation(fields: [ownerId], references: [id])

  @@index([ownerId])
}

model Tag {
  id        String   @id @default(cuid())
  name      String
  color     String?
  ownerId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  owner     User     @relation(fields: [ownerId], references: [id])
  tasks     Task[]   @relation("TagToTask")

  @@unique([name, ownerId])
  @@index([ownerId])
}

model Task {
  id             String    @id @default(cuid())
  title          String
  description    String?
  status         String    @default("TODO")
  priority       Int       @default(4)
  dueDate        DateTime?
  dueTime        String?
  isRecurring    Boolean   @default(false)
  recurrenceRule String?
  listId         String?
  tripId         String?
  ownerId        String
  parentId       String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  list           TaskList? @relation(fields: [listId], references: [id])
  owner          User      @relation(fields: [ownerId], references: [id])
  parent         Task?     @relation("SubTasks", fields: [parentId], references: [id])
  subTasks       Task[]    @relation("SubTasks")
  trip           Trip?     @relation(fields: [tripId], references: [id])
  tags           Tag[]     @relation("TagToTask")

  @@index([listId])
  @@index([dueDate])
}

model SmartLimit {
  id             String       @id @default(cuid())
  name           String
  amount         Int
  currency       String       @default("USD")
  category       String?
  location       String?
  isEnabled      Boolean      @default(true)
  organizationId String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
}

model Subscription {
  id              String       @id @default(cuid())
  name            String
  amount          Int
  currency        String       @default("USD")
  frequency       String
  status          String       @default("ACTIVE")
  lastPaymentDate DateTime?
  nextPaymentDate DateTime?
  detectedBy      String       @default("MANUAL")
  userId          String
  organizationId  String
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  organization    Organization @relation(fields: [organizationId], references: [id])
  user            User         @relation(fields: [userId], references: [id])

  @@index([organizationId])
  @@index([userId])
}

// -----------------------------------------------------------------------------
// HR & Employee Self-Service (ESS) Models
// -----------------------------------------------------------------------------

model EmployeeProfile {
  id              String    @id @default(cuid())
  userId          String    @unique
  dateOfBirth     DateTime?
  joiningDate     DateTime?
  jobTitle        String?
  department      String?
  managerId       String?
  emergencyContact String?
  taxIdNumber     String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([managerId])
}

model LeaveRecord {
  id          String   @id @default(cuid())
  userId      String
  type        String   // "SICK", "VACATION", "PERSONAL", "MATERNITY", "UNPAID"
  startDate   DateTime
  endDate     DateTime
  status      String   @default("PENDING") // "PENDING", "APPROVED", "REJECTED"
  reason      String?
  approverId  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

model Payslip {
  id          String   @id @default(cuid())
  userId      String
  month       Int
  year        Int
  grossPay    Int
  netPay      Int
  deductions  Int
  documentUrl String?
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, month, year])
  @@index([userId])
}

model PerformanceReview {
  id          String   @id @default(cuid())
  userId      String
  reviewerId  String?
  periodStart DateTime
  periodEnd   DateTime
  rating      Int?
  comments    String?
  status      String   @default("DRAFT") // "DRAFT", "SUBMITTED", "ACKNOWLEDGED"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
